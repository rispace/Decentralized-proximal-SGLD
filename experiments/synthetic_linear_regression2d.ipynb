   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "import os\n",
    "sys.path.append(os.path.abspath(os.path.join('..')))\n",
    "import numpy as np\n",
    "import seaborn as sns\n",
    "import matplotlib.pyplot as plt\n",
    "import utils.helpers as hlp\n",
    "from samplers.linear_models import BayesianRegression"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "1513077e",
   "metadata": {},
   "outputs": [],
   "source": [
    "seed = 42\n",
    "rng = np.random.default_rng(seed)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "2631b06e",
   "metadata": {},
   "outputs": [],
   "source": [
    "def data_generator(\n",
    "    num_data=1000, beta_star=None,\n",
    "    sigma=0.5, seed=seed\n",
    "):\n",
    "    \"\"\" \n",
    "    X: (num_data, dim), y: (num_data,)\n",
    "    beta_star: (dim,)\n",
    "    \"\"\"\n",
    "    beta_star = np.asarray(beta_star)\n",
    "    dim = beta_star.size\n",
    "    rng = np.random.default_rng(seed)\n",
    "    X = rng.standard_normal(size=(num_data, dim))\n",
    "    y = X @ beta_star + sigma * rng.standard_normal(size=num_data)\n",
    "    return X, y"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d23cf2b6",
   "metadata": {},
   "source": [
    "# 2D Experiments With Synthetic Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "3df6e2b0",
   "metadata": {},
   "outputs": [],
   "source": [
    "# True Parameters \n",
    "beta_star = [1.0, 1.0]\n",
    "# Generate Data\n",
    "X, y = data_generator(\n",
    "    num_data=10000, beta_star=beta_star, sigma=0.5\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "20d1bd0a",
   "metadata": {},
   "source": [
    "## Ordinary Least Squares Estimates"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "4ac57cfa",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "OLS estimate: [0.98387736 0.99337022]\n"
     ]
    }
   ],
   "source": [
    "beta_ols = np.linalg.lstsq(X, y, rcond=None)[0]\n",
    "print(\"OLS estimate:\", beta_ols)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c93d720e",
   "metadata": {},
   "source": [
    "## Prior Distributions  \n",
    "\n",
    "We consider the prior distribution of the regression coefficients $\\mathbf{\\beta}=[\\beta_0, \\beta_1]^{\\top}$ is the uniform distribution over the $\\ell_p$ ball,  \n",
    "\n",
    "$B_{O}(0,s)=\\{\\beta\\in\\mathbb{R}^2: \\|\\mathbf{\\beta}\\|_{\\ell_p}\\le s\\}$. \n",
    "\n",
    "where, $s=t\\|\\beta^{OLS}\\|_p$ for $t\\in[0,1]$ is the boundary. \n",
    "\n",
    "[Code accepts only $p=1,2$]  \n",
    "\n",
    "### $\\ell_2$ Prior with $s=\\frac45\\beta^{OLS}$  "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "cd5e985b",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 800x800 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "lp = 2\n",
    "s = 0.8*np.linalg.norm(beta_ols, ord=lp)\n",
    "prior_dist = hlp.priors(dim=2, N=5000, s=s, lp=lp, rng=rng)\n",
    "beta_x=prior_dist.T[0]\n",
    "beta_y=prior_dist.T[1]\n",
    "\n",
    "X1 = np.linspace(-1.5, 1.5, 1000)\n",
    "Y = np.linspace(-1.5, 1.5, 1000)\n",
    "xx, yy = np.meshgrid(X1, Y)\n",
    "zz = np.power(\n",
    "    np.power(np.abs(xx), lp) + np.power(np.abs(yy), lp), 1/lp\n",
    ")\n",
    "fig = plt.figure(figsize=(8, 8))\n",
    "plt.contour(X1, Y, zz, [s])\n",
    "sns.kdeplot(\n",
    "    x=beta_x, y=beta_y, fill=True, levels=10\n",
    ")\n",
    "plt.scatter(beta_star[0], beta_star[1], c='r', s=200, marker=(5,1))\n",
    "plt.tick_params(labelsize=30)\n",
    "plt.savefig('images/prior_linreg_lp.png')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "505dd380",
   "metadata": {},
   "source": [
    "## Sampling from the posterior distribution"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "fb0ef7b4",
   "metadata": {},
   "outputs": [],
   "source": [
    "def regression_run(\n",
    "    X=X, y=y, N=50, batch_size=50, eta=5e-5,\n",
    "    gamma=1e-2, lp=lp, s=s, n_iteration=100,\n",
    "    size_w=8, sigma=0.5, seed=42,\n",
    "    nets=(\"fcn\", \"cn\", \"sn\", \"fdn\"),\n",
    "    figsize=(32, 16)\n",
    "):\n",
    "    fig, axes = plt.subplots(2, 4, figsize=figsize, sharey=False)\n",
    "    network_names = [\"Fully Connected\", \"Circular\", \"Star\", \"Disconnected\"]\n",
    "    \n",
    "    for j, (net, name) in enumerate(zip(nets, network_names)):\n",
    "        ax_top = axes[0, j]\n",
    "        ax_bottom = axes[1, j]\n",
    "        model = BayesianRegression(\n",
    "            X=X, y=y, N=N, batch_size=batch_size,\n",
    "            eta=eta, gamma=gamma, lp=lp, s=s,\n",
    "            n_iteration=n_iteration,\n",
    "            size_w=size_w, sigma=sigma,\n",
    "            net=net, seed=seed, type='linear'\n",
    "        )\n",
    "        history_all, beta_mean_all = model.sample_parameters(\n",
    "            method='dpsgld'\n",
    "        )\n",
    "        X1 = np.linspace(-1.5, 1.5, 1000)\n",
    "        Y1 = np.linspace(-1.5, 1.5, 1000)\n",
    "        xx, yy = np.meshgrid(X1, Y1)\n",
    "        zz = np.power(\n",
    "            np.power(np.abs(xx), lp) + np.power(np.abs(yy), lp), 1/lp\n",
    "        )\n",
    "        ax_top.contour(X1, Y1, zz, [s])\n",
    "        agent = rng.integers(0, size_w)\n",
    "        sns.kdeplot(\n",
    "            x=history_all[-1,agent,0,:],\n",
    "            y=history_all[-1,agent,1,:],\n",
    "            fill=True, levels=10, ax=ax_top\n",
    "        )\n",
    "        ax_top.scatter(\n",
    "            beta_star[0], beta_star[1],\n",
    "            c='r', s=200, marker=(5,1)\n",
    "        )\n",
    "        ax_top.set_title(f\"{name}\\nAgent {agent}\", fontsize=30)\n",
    "        ax_top.tick_params(axis=\"both\", labelsize=28)\n",
    "        \n",
    "        ax_bottom.contour(X1, Y1, zz, [s])\n",
    "        sns.kdeplot(\n",
    "            x=beta_mean_all[-1, 0, :],\n",
    "            y=beta_mean_all[-1, 1, :],\n",
    "            fill=True, levels=10, ax=ax_bottom\n",
    "        )\n",
    "        ax_bottom.scatter(\n",
    "            beta_star[0], beta_star[1],\n",
    "            c='r', s=200, label='OLS', marker=(5,1)\n",
    "        )\n",
    "        ax_bottom.set_title(f\"{name}\\nMean\", fontsize=30)\n",
    "        ax_bottom.tick_params(axis=\"both\", labelsize=28)\n",
    "    plt.tight_layout()\n",
    "    plt.savefig('images/regression2dsample.png')\n",
    "    plt.show()"
   ]
  },
  {
